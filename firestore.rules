rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Authenticated users: full access to their own data ──────────────────
    // Covers all subcollections: properties, staff, rooms, dailyLogs, etc.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Housekeeper mobile page: public read + update on rooms ──────────────
    // Rooms live at: users/{uid}/properties/{pid}/rooms/{rid}
    // The housekeeper page uses collectionGroup('rooms') with no auth token.
    // Only read and update are allowed — public creation/deletion is blocked.
    match /{path=**}/rooms/{rid} {
      allow read: if true;
      allow update: if true;
    }
  }
}
