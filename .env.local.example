# Firebase Configuration
# 1. Go to https://console.firebase.google.com
# 2. Create a new project called "hotelops-ai"
# 3. Enable Google Authentication (Authentication > Sign-in method > Google)
# 4. Create a Firestore database (Firestore Database > Create database)
# 5. Register a Web App (Project Settings > Your apps > Web app)
# 6. Copy the config values below

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
